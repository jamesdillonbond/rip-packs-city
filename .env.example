# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://bxcqstmqfzmuolpuynti.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Flow Blockchain ──────────────────────────────────────────────────────────
NEXT_PUBLIC_FLOW_NETWORK=mainnet

# ─── Site URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rip-packs-city.vercel.app
NEXT_PUBLIC_APP_URL=https://rip-packs-city.vercel.app

# ─── AI Concierge (Claude Sonnet) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Cron / Pipeline Auth ─────────────────────────────────────────────────────
INGEST_SECRET_TOKEN=your-ingest-secret
CRON_SECRET=your-cron-secret

# ─── Top Shot Proxy (Cloudflare Worker) ────────────────────────────────────────
TS_PROXY_URL=https://your-worker.workers.dev
TS_PROXY_SECRET=your-proxy-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
ALERT_EMAIL=alerts@rippackscity.com

# ─── Telegram Sentinel Bot ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─── Twitter / X  (RPC brand) ─────────────────────────────────────────────────
RPC_X_API_KEY=your-x-api-key
RPC_X_API_SECRET=your-x-api-secret
RPC_X_ACCESS_TOKEN=your-x-access-token
RPC_X_ACCESS_SECRET=your-x-access-secret
TWITTER_BOT_ENABLED=false

# ─── Twitter / X  (Flowty brand — optional) ───────────────────────────────────
FLOWTY_X_API_KEY=
FLOWTY_X_API_SECRET=
FLOWTY_X_ACCESS_TOKEN=
FLOWTY_X_ACCESS_SECRET=

# ─── OpenSea (Panini collection — optional) ───────────────────────────────────
OPENSEA_API_KEY=your-opensea-api-key

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_FLOWTY_MARKET_PROBES=true
ENABLE_TOPSHOT_DOCS_PROBES=true
MARKET_FEED_TOKEN=your-market-feed-token
